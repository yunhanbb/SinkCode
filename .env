# Feishu app credentials
FEISHU_APP_ID=cli_a9310cf8eb7a9bce
FEISHU_APP_SECRET=86pNQLa6lAji5T2RCNlLdf4tzgtqRUCT

# Values from Feishu Event Subscription page
FEISHU_VERIFICATION_TOKEN=WHcRFwPncB8t2mrGxdOAGY3r2sHm6qR4
# If you disabled event encryption, keep it empty
FEISHU_ENCRYPT_KEY=

# Runtime config
SHELL_PATH=/bin/zsh
OPENCODEX_CLIENT_NAME=
STATE_FILE=.bridge_state.json
LOG_FILE=bridge.log
HISTORY_DIR=history
FLUSH_INTERVAL_SECONDS=1.2
CODEX_FLUSH_INTERVAL_SECONDS=0.35
CARD_UPDATE_INTERVAL_SECONDS=0.8
CARD_STATUS_MAX_LINES=18
CARD_ANSWER_MAX_CHARS=2600
TYPEWRITER_STATUS_CHARS_PER_TICK=8
TYPEWRITER_ANSWER_CHARS_PER_TICK=24
MAX_MESSAGE_CHARS=1200

# Optional command guard; only commands starting with one of these prefixes are allowed.
# Example: codex,ls,pwd,git
ALLOWED_COMMAND_PREFIXES=

# TLS options for environments with HTTPS interception/proxy:
# 1) Preferred: set corporate root CA cert path (PEM)
FEISHU_CA_CERT_PATH=
# 2) Last resort (unsafe): disable TLS verify
FEISHU_INSECURE_SKIP_VERIFY=true

# Schema 2.0 card template mode (recommended by Feishu CardKit)
# Fill with a published template id like ctp_xxxxx
CARD_TEMPLATE_ID=AAqK4drHMTtX4
# Optional: dedicated templates for the three OpenCodex cards.
# If left empty, the bridge falls back to CARD_TEMPLATE_ID.
GENERAL_CARD_TEMPLATE_ID=AAqKd86klHLVH
CODEX_CARD_TEMPLATE_ID=AAqKdwEOezfsO
MATH_CARD_TEMPLATE_ID=AAqKd8MQVMccX
# Variable key in your template that receives markdown text
CARD_TEMPLATE_VAR_NAME=content
CARD_STATUS_VAR_NAME=status_content
CARD_ANSWER_VAR_NAME=answer_content
